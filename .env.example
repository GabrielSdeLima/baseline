# Database
DATABASE_URL=postgresql+asyncpg://baseline:baseline@localhost:5433/baseline

# Scale BLE scan subprocess timeout in seconds (default: 45)
# SCALE_SCAN_TIMEOUT=45

# Script-side env vars (read directly by scripts/, not through Settings):
#
# BASELINE_API_URL — target API base URL for sync_garmin.py / import_scale.py
#   Default: http://localhost:8000
#   Override for dev mode: BASELINE_API_URL=http://localhost:8001
#
# BASELINE_USER_ID — fallback for --user-id flag in scripts.  When set, you can
#   run scripts without passing --user-id on the CLI (useful for scheduled tasks).
#
# BASELINE_PULSO_APP_DIR — path to the Pulso Flutter app (decoder source).
#   Default: C:/src/pulso/pulso-app
